{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "ignoreDeprecations": "5.0",
    "moduleResolution": "node",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "./dist",
    "rootDir": ".",
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true
  },
  "include": [
    "src/**/*",
    "src/lib/**/*",
    "index.ts",
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}